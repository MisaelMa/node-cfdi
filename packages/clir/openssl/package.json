{
  "name": "@clir/openssl",
  "version": "0.0.17-dev.2",
  "description": "Wrapper de OpenSSL CLI para certificados digitales del SAT",
  "homepage": "https://cfdi.recreando.dev",
  "bugs": {
    "url": "https://github.com/MisaelMa/node-cfdi/issues"
  },
