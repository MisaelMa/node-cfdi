{
  "name": "@cfdi/catalogos-codegen",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "catalogos-codegen": "./bin/cli.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "generate": "tsx bin/cli.ts",
    "generate:force": "tsx bin/cli.ts --force-download",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@sat/recursos": "workspace:*",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@recreando/eslint-settings": "workspace:*",
    "@recreando/typescript-settings": "workspace:*",
    "@types/node": "^22",
    "eslint": "^8.57.0",
    "tsx": "^4.7.0",
    "typescript": "^5.6.3",
    "vite-tsconfig-paths": "~4.2.1",
    "vitest": "2.1.3",
    "@vitest/coverage-v8": "2.1.3",
    "@vitest/ui": "2.1.3"
  }
}
